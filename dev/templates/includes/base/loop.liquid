<ul class="postlist">
  {% for post in posts %}
    <li class="postlist-item">
      <a href="{{ post.url }}" class="postlist-link">
        <article class="postlist-article">
          <h3 class="postlist-title">{{ post.data.title }}</h3>
          <img
            src="{{ post.data.thumbnail | default: global.post_thumbnail }}"
            alt="{{ post.data.title }}"
            class="postlist-thumbnail" />
          <p class="postlist-excerpt">
            {{ post.templateContent | strip_html | truncatewords: 40, ' <b class="readmore">--Read More--</b>' }}
          </p>
          <time class="postlist-date" datetime="{{ post.date | date: "%Y-%m-%d" }}">{{ post.date | date: "%b %d %Y" }}</time>
        </article>
      </a>
    </li>
  {% endfor %}
</ul>